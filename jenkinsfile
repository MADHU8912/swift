pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/MADHU8912/swift.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run App Check') {
            steps {
                bat 'node --version'
                bat 'npm --version'
            }
        }
    }
}
